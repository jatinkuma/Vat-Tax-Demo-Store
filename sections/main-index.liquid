{%- style -%}
  /* ===== ESTS TAX/VAT SWITCHER — HERO SECTION ===== */
  .vat-hero {
    min-height: auto;
    background: #0C0C0C;
    background-image:
      radial-gradient(ellipse 70% 50% at 50% -5%, rgba(249, 115, 22, 0.18) 0%, transparent 65%),
      radial-gradient(ellipse 40% 30% at 80% 80%, rgba(249, 115, 22, 0.06) 0%, transparent 60%);
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 140px 24px 80px;
  }

  .vat-hero__content {
    position: relative;
    z-index: 2;
    max-width: 860px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .vat-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 7px 18px;
    background: rgba(249, 115, 22, 0.1);
    border: 1px solid rgba(249, 115, 22, 0.3);
    border-radius: 9999px;
    font-size: 12px;
    font-weight: 600;
    color: #F97316;
    margin-bottom: 28px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    animation: vatFadeUp 0.6s ease both;
  }

  .vat-hero__badge-dot {
    width: 6px;
    height: 6px;
    background: #F97316;
    border-radius: 50%;
    animation: vatPulse 2s ease infinite;
  }

  .vat-hero__headline {
    font-size: clamp(2.6rem, 6.5vw, 5rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.04em;
    color: #F1F5F9;
    margin: 0 0 24px;
    animation: vatFadeUp 0.6s ease both 0.1s;
  }

  .vat-hero__headline-orange {
    color: #F97316;
    position: relative;
  }

  .vat-hero__subtext {
    font-size: 1.15rem;
    color: #94A3B8;
    max-width: 600px;
    margin: 0 0 40px;
    line-height: 1.7;
    animation: vatFadeUp 0.6s ease both 0.2s;
  }

  .vat-hero__actions {
    display: flex;
    gap: 14px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
    animation: vatFadeUp 0.6s ease both 0.3s;
    margin-bottom: 60px;
  }

  .vat-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #F97316, #EA580C);
    color: #fff;
    padding: 14px 32px;
    border-radius: 9999px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 8px 28px rgba(249, 115, 22, 0.45);
    transition: all 0.3s ease;
    letter-spacing: 0.1px;
  }

  .vat-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 36px rgba(249, 115, 22, 0.6);
    filter: brightness(1.08);
    color: #fff;
  }

  .vat-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 255, 255, 0.06);
    color: #F1F5F9;
    padding: 14px 28px;
    border-radius: 9999px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all 0.3s ease;
  }

  .vat-btn-secondary:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    color: #fff;
  }

  /* VAT Toggle Demo Preview */
  .vat-hero__demo {
    animation: vatFadeUp 0.6s ease both 0.4s;
    background: rgba(20, 20, 20, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 24px 32px;
    display: flex;
    align-items: center;
    gap: 24px;
    backdrop-filter: blur(12px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    flex-wrap: wrap;
    justify-content: center;
  }

  .vat-demo-label {
    font-size: 12px;
    color: #64748B;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }

  .vat-demo-toggle {
    display: flex;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 9999px;
    padding: 4px;
    gap: 4px;
  }

  .vat-demo-btn {
    padding: 8px 20px;
    border-radius: 9999px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    border: none;
    transition: all 0.25s ease;
  }

  .vat-demo-btn--on {
    background: linear-gradient(135deg, #F97316, #EA580C);
    color: #fff;
    box-shadow: 0 3px 10px rgba(249, 115, 22, 0.4);
  }

  .vat-demo-btn--off {
    background: transparent;
    color: #64748B;
  }

  .vat-demo-price {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .vat-demo-price-main {
    font-size: 22px;
    font-weight: 800;
    color: #F1F5F9;
    line-height: 1;
  }

  .vat-demo-price-tag {
    font-size: 11px;
    color: #F97316;
    font-weight: 600;
    margin-top: 3px;
  }

  .vat-demo-arrow {
    color: #64748B;
    font-size: 18px;
  }

  /* Stats row */
  .vat-hero__stats {
    display: flex;
    gap: 32px;
    margin-top: 32px;
    animation: vatFadeUp 0.6s ease both 0.5s;
    flex-wrap: wrap;
    justify-content: center;
    padding: 20px 32px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
  }

  .vat-stat {
    text-align: center;
  }

  .vat-stat__number {
    font-size: 1.8rem;
    font-weight: 800;
    color: #F97316;
    line-height: 1;
    display: block;
  }

  .vat-stat__label {
    font-size: 12px;
    color: #64748B;
    margin-top: 4px;
    font-weight: 500;
  }

  /* Animations */
  @keyframes vatFadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes vatPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.3); }
  }

  @media screen and (max-width: 768px) {
    .vat-hero {
      padding: 120px 20px 60px;
    }
    .vat-hero__headline {
      font-size: 2.2rem;
    }
    .vat-hero__subtext {
      font-size: 1rem;
    }
    .vat-hero__demo {
      padding: 18px 20px;
      gap: 16px;
    }
    .vat-hero__stats {
      gap: 24px;
    }
  }
{%- endstyle -%}

<section class="vat-hero" aria-label="Ests Tax/VAT Switcher Hero">
  <div class="vat-hero__content">

    <div class="vat-hero__badge">
      <span class="vat-hero__badge-dot"></span>
      Shopify App — VAT / Tax Switcher
    </div>

    <h1 class="vat-hero__headline">
      {{ section.settings.headline | default: 'Switch VAT Pricing Instantly for B2B &amp; B2C' }}
    </h1>

    <p class="vat-hero__subtext">
      {{ section.settings.subtext | default: 'Ests Tax/VAT Switcher helps merchants display prices with or without VAT for both business and individual customers. Prices update instantly across product, collection, and cart pages.' }}
    </p>

    <div class="vat-hero__actions">
      <a href="{{ section.settings.primary_cta_url | default: 'https://apps.shopify.com/vat-switcher' }}" class="vat-btn-primary" target="_blank" rel="noopener noreferrer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        {{ section.settings.primary_cta_label | default: 'Install App on Shopify' }}
      </a>
      <a href="{{ section.settings.secondary_cta_url | default: routes.collections_url }}" class="vat-btn-secondary">
        {{ section.settings.secondary_cta_label | default: 'View Live Demo' }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    <!-- Live VAT Toggle Demo -->
    <div class="vat-hero__demo" role="region" aria-label="VAT toggle demonstration">
      <span class="vat-demo-label">Live Demo</span>
      <div class="vat-demo-toggle" role="group" aria-label="Customer type">
        <button class="vat-demo-btn vat-demo-btn--on" id="vatDemoB2B" aria-pressed="true">&#127970; Business</button>
        <button class="vat-demo-btn vat-demo-btn--off" id="vatDemoB2C" aria-pressed="false">&#128100; Individual</button>
      </div>
      <div class="vat-demo-price">
        <span class="vat-demo-price-main" id="vatDemoPrice">€82.64</span>
        <span class="vat-demo-price-tag" id="vatDemoTag">excl. VAT</span>
      </div>
      <span class="vat-demo-arrow" aria-hidden="true">⇄</span>
      <div class="vat-demo-price">
        <span class="vat-demo-price-main" style="color:#64748B;">€100.00</span>
        <span class="vat-demo-price-tag" style="color:#64748B;">incl. VAT</span>
      </div>
    </div>

    <!-- Stats row -->
  <div class="vat-hero__stats" aria-label="App statistics">
      <div class="vat-stat">
        <span class="vat-stat__number">20%</span>
        <span class="vat-stat__label">Default VAT Rate</span>
      </div>
      <div class="vat-stat">
        <span class="vat-stat__number">3</span>
        <span class="vat-stat__label">Popup Templates</span>
      </div>
      <div class="vat-stat">
        <span class="vat-stat__number">0</span>
        <span class="vat-stat__label">Code Changes Needed</span>
      </div>
      <div class="vat-stat">
        <span class="vat-stat__number">B2B+B2C</span>
        <span class="vat-stat__label">Customer Modes</span>
      </div>
    </div>

  </div>
</section>

<script>
  (function() {
    var b2bBtn = document.getElementById('vatDemoB2B');
    var b2cBtn = document.getElementById('vatDemoB2C');
    var priceEl = document.getElementById('vatDemoPrice');
    var tagEl = document.getElementById('vatDemoTag');
    if (!b2bBtn || !b2cBtn) return;
    b2bBtn.addEventListener('click', function() {
      b2bBtn.className = 'vat-demo-btn vat-demo-btn--on';
      b2cBtn.className = 'vat-demo-btn vat-demo-btn--off';
      b2bBtn.setAttribute('aria-pressed', 'true');
      b2cBtn.setAttribute('aria-pressed', 'false');
      priceEl.textContent = '€82.64';
      tagEl.textContent = 'excl. VAT';
    });
    b2cBtn.addEventListener('click', function() {
      b2cBtn.className = 'vat-demo-btn vat-demo-btn--on';
      b2bBtn.className = 'vat-demo-btn vat-demo-btn--off';
      b2cBtn.setAttribute('aria-pressed', 'true');
      b2bBtn.setAttribute('aria-pressed', 'false');
      priceEl.textContent = '€100.00';
      tagEl.textContent = 'incl. VAT';
    });
  })();
</script>

{% schema %}
{
  "name": "VAT Switcher Hero",
  "settings": [
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Switch VAT Pricing Instantly for B2B & B2C"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Ests Tax/VAT Switcher helps merchants display prices with or without VAT for both business and individual customers. Prices update instantly across product, collection, and cart pages."
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "Primary Button Label",
      "default": "Install Free on Shopify"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "Primary Button URL"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "Secondary Button Label",
      "default": "View Live Demo"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "Secondary Button URL"
    }
  ],
  "presets": [
    {
      "name": "VAT Switcher Hero"
    }
  ]
}
{% endschema %}
