{%- style -%}
  /* ===== VAT SWITCHER — CTA SECTION ===== */
  .vat-cta {
    padding: 100px 0;
    background: #0C0C0C;
    position: relative;
  }
  .vat-cta::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(249,115,22,0.3), transparent);
  }
  .vat-cta-container {
    background: linear-gradient(135deg, #1A0A00 0%, #1A1A1A 50%, #0A0A0A 100%);
    border: 1px solid rgba(249,115,22,0.2);
    border-radius: 28px;
    padding: 80px 48px;
    text-align: center;
    position: relative;
    overflow: hidden;
    box-shadow: 0 0 80px rgba(249,115,22,0.08), inset 0 1px 0 rgba(249,115,22,0.1);
  }
  .vat-cta-container::before {
    content: '';
    position: absolute;
    top: -100px; left: 50%; transform: translateX(-50%);
    width: 600px; height: 300px;
    background: radial-gradient(ellipse, rgba(249,115,22,0.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .vat-cta-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 16px;
    background: rgba(249,115,22,0.1);
    border: 1px solid rgba(249,115,22,0.25);
    border-radius: 9999px;
    font-size: 12px;
    font-weight: 600;
    color: #F97316;
    margin-bottom: 24px;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    position: relative;
    z-index: 2;
  }
  .vat-cta-heading {
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    color: #F1F5F9;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0 0 20px;
    position: relative;
    z-index: 2;
  }
  .vat-cta-heading span { color: #F97316; }
  .vat-cta-text {
    font-size: 1.05rem;
    color: #94A3B8;
    max-width: 520px;
    margin: 0 auto 40px;
    line-height: 1.7;
    position: relative;
    z-index: 2;
  }
  .vat-cta-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
  }
  .vat-cta-btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: linear-gradient(135deg, #F97316, #EA580C);
    color: #fff;
    padding: 16px 36px;
    border-radius: 9999px;
    font-size: 15px;
    font-weight: 700;
    text-decoration: none;
    box-shadow: 0 8px 28px rgba(249,115,22,0.45);
    transition: all 0.3s ease;
  }
  .vat-cta-btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 14px 40px rgba(249,115,22,0.6);
    color: #fff;
  }
  .vat-cta-btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255,255,255,0.06);
    color: #F1F5F9;
    padding: 16px 28px;
    border-radius: 9999px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,0.1);
    transition: all 0.3s ease;
  }
  .vat-cta-btn-secondary:hover {
    background: rgba(255,255,255,0.1);
    color: #fff;
  }
  .vat-cta-note {
    margin-top: 20px;
    font-size: 13px;
    color: #475569;
    position: relative;
    z-index: 2;
  }
  @media screen and (max-width: 749px) {
    .vat-cta-container { padding: 56px 24px; }
    .vat-cta-heading { font-size: 2rem; }
  }
{%- endstyle -%}

<section class="vat-cta" aria-labelledby="vat-cta-heading">
  <div class="page-width">
    <div class="vat-cta-container">
      <div class="vat-cta-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        Free to Install on Shopify
      </div>
      <h2 class="vat-cta-heading" id="vat-cta-heading">
        Start showing the right price<br>to <span>every customer</span>
      </h2>
      <p class="vat-cta-text">
        Ests Tax/VAT Switcher is the easiest way to serve both B2B and B2C customers with correct VAT pricing — no code, no complexity.
      </p>
      <div class="vat-cta-actions">
        <a href="https://apps.shopify.com/vat-switcher" class="vat-cta-btn-primary" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
          Install Free on Shopify
        </a>
        <a href="{{ routes.collections_url }}" class="vat-cta-btn-secondary">
          Browse Products
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
      <p class="vat-cta-note">Works with any Shopify 2.0 theme &nbsp;·&nbsp; Zero code changes &nbsp;·&nbsp; B2B &amp; B2C ready</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VAT CTA Section",
  "tag": "section",
  "class": "section",
  "presets": [
    { "name": "VAT CTA Section" }
  ]
}
{% endschema %}
