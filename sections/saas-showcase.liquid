{%- style -%}
  /* ===== VAT SWITCHER — HOW IT WORKS SHOWCASE ===== */
  .vat-showcase {
    padding: 100px 0;
    background: #0E0E0E;
    position: relative;
  }
  .vat-showcase::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
  }
  .vat-showcase__header {
    text-align: center;
    margin-bottom: 64px;
  }
  .vat-showcase-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .vat-showcase-card {
    background: #141414;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.16,1,0.3,1);
    display: flex;
    flex-direction: column;
  }
  .vat-showcase-card:hover {
    border-color: rgba(249,115,22,0.2);
    transform: translateY(-6px);
    box-shadow: 0 24px 56px rgba(0,0,0,0.5);
  }
  .vat-showcase-visual {
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    background: #1A1A1A;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  /* Popup preview visual */
  .vat-popup-preview {
    background: #1E1E1E;
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 16px;
    padding: 20px 24px;
    width: 200px;
    text-align: center;
    box-shadow: 0 16px 40px rgba(0,0,0,0.6);
  }
  .vat-popup-preview__title {
    font-size: 13px;
    font-weight: 700;
    color: #F1F5F9;
    margin-bottom: 4px;
  }
  .vat-popup-preview__title span { color: #F97316; }
  .vat-popup-preview__sub {
    font-size: 10px;
    color: #64748B;
    margin-bottom: 14px;
  }
  .vat-popup-preview__btns {
    display: flex;
    gap: 8px;
  }
  .vat-popup-btn {
    flex: 1;
    padding: 7px 4px;
    border-radius: 8px;
    font-size: 10px;
    font-weight: 700;
    text-align: center;
  }
  .vat-popup-btn--biz {
    background: linear-gradient(135deg, #F97316, #EA580C);
    color: #fff;
  }
  .vat-popup-btn--ind {
    background: rgba(255,255,255,0.06);
    color: #94A3B8;
    border: 1px solid rgba(255,255,255,0.08);
  }
  /* Price toggle visual */
  .vat-price-preview {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 200px;
  }
  .vat-price-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #1E1E1E;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    padding: 10px 14px;
  }
  .vat-price-row--active {
    border-color: rgba(249,115,22,0.3);
    background: rgba(249,115,22,0.06);
  }
  .vat-price-row__label { font-size: 11px; color: #64748B; font-weight: 500; }
  .vat-price-row__amount { font-size: 14px; font-weight: 800; color: #F1F5F9; }
  .vat-price-row--active .vat-price-row__amount { color: #F97316; }
  .vat-price-row__tag { font-size: 9px; color: #F97316; font-weight: 600; }
  /* Settings visual */
  .vat-settings-preview {
    background: #1E1E1E;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    padding: 16px;
    width: 200px;
  }
  .vat-settings-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .vat-settings-row:last-child { margin-bottom: 0; }
  .vat-settings-row__label { font-size: 10px; color: #64748B; }
  .vat-settings-row__val { font-size: 10px; color: #F97316; font-weight: 700; }
  .vat-settings-swatch {
    width: 16px; height: 16px; border-radius: 4px;
  }
  /* Card content */
  .vat-showcase-content {
    padding: 24px;
    flex-grow: 1;
  }
  .vat-showcase-step {
    font-size: 11px;
    font-weight: 700;
    color: #F97316;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  .vat-showcase-title {
    font-size: 18px;
    font-weight: 700;
    color: #F1F5F9;
    margin: 0 0 10px;
    line-height: 1.3;
  }
  .vat-showcase-text {
    font-size: 14px;
    color: #64748B;
    line-height: 1.7;
    margin: 0;
  }
  @media screen and (max-width: 989px) {
    .vat-showcase-grid { grid-template-columns: 1fr; max-width: 480px; margin: 0 auto; }
  }
{%- endstyle -%}

<section class="vat-showcase" aria-labelledby="vat-showcase-heading">
  <div class="page-width">
    <div class="vat-showcase__header">
      <span class="vat-section-label">How It Works</span>
      <h2 class="vat-section-title" id="vat-showcase-heading">
        See it in <span>action</span>
      </h2>
      <p class="vat-section-subtitle">
        Three simple steps — your customers choose their mode, prices update instantly.
      </p>
    </div>

    <div class="vat-showcase-grid">

      <!-- Step 1: Welcome Popup -->
      <div class="vat-showcase-card">
        <div class="vat-showcase-visual" aria-hidden="true">
          <div class="vat-popup-preview">
            <div class="vat-popup-preview__title">Welcome to <span>Tax Selector</span></div>
            <div class="vat-popup-preview__sub">I act as a:</div>
            <div class="vat-popup-preview__btns">
              <div class="vat-popup-btn vat-popup-btn--biz">&#127970; Business<br><small>excl. VAT</small></div>
              <div class="vat-popup-btn vat-popup-btn--ind">&#128100; Individual<br><small>incl. VAT</small></div>
            </div>
          </div>
        </div>
        <div class="vat-showcase-content">
          <div class="vat-showcase-step">Step 1</div>
          <h3 class="vat-showcase-title">Customer Chooses Their Mode</h3>
          <p class="vat-showcase-text">New visitors see a welcome popup asking if they're a Business (excl. VAT) or Individual (incl. VAT) customer. Their preference is saved for future visits.</p>
        </div>
      </div>

      <!-- Step 2: Price Toggle -->
      <div class="vat-showcase-card">
        <div class="vat-showcase-visual" aria-hidden="true">
          <div class="vat-price-preview">
            <div class="vat-price-row vat-price-row--active">
              <div>
                <div class="vat-price-row__label">Business Mode</div>
                <div class="vat-price-row__amount">€82.64</div>
              </div>
              <div class="vat-price-row__tag">excl. VAT ✓</div>
            </div>
            <div class="vat-price-row">
              <div>
                <div class="vat-price-row__label">Individual Mode</div>
                <div class="vat-price-row__amount">€100.00</div>
              </div>
              <div class="vat-price-row__tag" style="color:#64748B;">incl. VAT</div>
            </div>
          </div>
        </div>
        <div class="vat-showcase-content">
          <div class="vat-showcase-step">Step 2</div>
          <h3 class="vat-showcase-title">Prices Update Across All Pages</h3>
          <p class="vat-showcase-text">Product pages, collection pages, and the cart all show the correct price instantly — no page reload needed. The header toggle lets customers switch anytime.</p>
        </div>
      </div>

      <!-- Step 3: Merchant Settings -->
      <div class="vat-showcase-card">
        <div class="vat-showcase-visual" aria-hidden="true">
          <div class="vat-settings-preview">
            <div class="vat-settings-row">
              <span class="vat-settings-row__label">Tax Rate</span>
              <span class="vat-settings-row__val">20%</span>
            </div>
            <div class="vat-settings-row">
              <span class="vat-settings-row__label">Prices Include Tax</span>
              <span class="vat-settings-row__val">✓ Yes</span>
            </div>
            <div class="vat-settings-row">
              <span class="vat-settings-row__label">Popup Template</span>
              <span class="vat-settings-row__val">Template 1</span>
            </div>
            <div class="vat-settings-row">
              <span class="vat-settings-row__label">Button Color</span>
              <span class="vat-settings-swatch" style="background:#F97316;"></span>
            </div>
            <div class="vat-settings-row">
              <span class="vat-settings-row__label">Header Toggle</span>
              <span class="vat-settings-row__val">Enabled</span>
            </div>
          </div>
        </div>
        <div class="vat-showcase-content">
          <div class="vat-showcase-step">Step 3</div>
          <h3 class="vat-showcase-title">Merchant Configures Everything</h3>
          <p class="vat-showcase-text">Set your tax rate, choose popup templates, customize colors and text — all from the app settings. No theme code editing required.</p>
        </div>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "VAT Showcase",
  "tag": "section",
  "class": "section",
  "presets": [
    { "name": "VAT Showcase" }
  ]
}
{% endschema %}
