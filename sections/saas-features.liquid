{%- style -%}
  /* ===== VAT SWITCHER — FEATURES SECTION ===== */
  .vat-features {
    padding: 100px 0;
    background: #0C0C0C;
    position: relative;
  }
  .vat-features::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(249,115,22,0.3), transparent);
  }
  .vat-features__header {
    text-align: center;
    margin-bottom: 64px;
  }
  .vat-section-label {
    display: inline-block;
    color: #F97316;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 16px;
    padding: 5px 14px;
    background: rgba(249,115,22,0.1);
    border: 1px solid rgba(249,115,22,0.2);
    border-radius: 9999px;
  }
  .vat-section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #F1F5F9;
    letter-spacing: -0.04em;
    line-height: 1.1;
    margin: 0 0 16px;
  }
  .vat-section-title span { color: #F97316; }
  .vat-section-subtitle {
    font-size: 1.05rem;
    color: #64748B;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .vat-features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .vat-feature-card {
    background: #141414;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 20px;
    padding: 32px;
    transition: all 0.35s cubic-bezier(0.16,1,0.3,1);
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }
  .vat-feature-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(249,115,22,0), transparent);
    transition: background 0.35s ease;
  }
  .vat-feature-card:hover {
    border-color: rgba(249,115,22,0.25);
    background: #181818;
    transform: translateY(-6px);
    box-shadow: 0 20px 48px rgba(0,0,0,0.5), 0 0 0 1px rgba(249,115,22,0.1);
  }
  .vat-feature-card:hover::before {
    background: linear-gradient(90deg, transparent, rgba(249,115,22,0.6), transparent);
  }
  .vat-feature-icon {
    width: 48px;
    height: 48px;
    background: rgba(249,115,22,0.1);
    border: 1px solid rgba(249,115,22,0.2);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    color: #F97316;
    flex-shrink: 0;
  }
  .vat-feature-title {
    font-size: 17px;
    font-weight: 700;
    color: #F1F5F9;
    margin: 0 0 10px;
    line-height: 1.3;
  }
  .vat-feature-text {
    font-size: 14px;
    color: #64748B;
    line-height: 1.7;
    margin: 0;
    flex-grow: 1;
  }
  /* Wide card spanning 2 cols */
  .vat-feature-card--wide {
    grid-column: span 2;
    flex-direction: row;
    align-items: flex-start;
    gap: 28px;
  }
  .vat-feature-card--wide .vat-feature-icon {
    flex-shrink: 0;
    margin-bottom: 0;
  }
  .vat-feature-card--wide .vat-feature-body { flex: 1; }
  @media screen and (max-width: 989px) {
    .vat-features-grid { grid-template-columns: repeat(2, 1fr); }
    .vat-feature-card--wide { grid-column: span 2; }
  }
  @media screen and (max-width: 749px) {
    .vat-features-grid { grid-template-columns: 1fr; }
    .vat-feature-card--wide { grid-column: span 1; flex-direction: column; }
    .vat-feature-card--wide .vat-feature-icon { margin-bottom: 20px; }
  }
{%- endstyle -%}

<section class="vat-features" aria-labelledby="vat-features-heading">
  <div class="page-width">
    <div class="vat-features__header">
      <span class="vat-section-label">App Features</span>
      <h2 class="vat-section-title" id="vat-features-heading">
        Everything you need for<br><span>VAT / Tax Switching</span>
      </h2>
      <p class="vat-section-subtitle">
        Ests Tax/VAT Switcher gives merchants full control over how prices are displayed — no code, no complexity.
      </p>
    </div>

    <div class="vat-features-grid">

      <!-- Feature 1 — Toggle -->
      <div class="vat-feature-card">
        <div class="vat-feature-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/></svg>
        </div>
        <h3 class="vat-feature-title">Instant VAT Toggle</h3>
        <p class="vat-feature-text">Switch between VAT inclusive and exclusive pricing instantly with a single click. Prices update in real-time across your entire storefront.</p>
      </div>

      <!-- Feature 2 — Popup -->
      <div class="vat-feature-card">
        <div class="vat-feature-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
        </div>
        <h3 class="vat-feature-title">Welcome Popup</h3>
        <p class="vat-feature-text">Show new customers a popup to choose Business or Individual mode. They see excl. VAT or incl. VAT prices based on their selection.</p>
      </div>

      <!-- Feature 3 — Dynamic Prices (wide) -->
      <div class="vat-feature-card vat-feature-card--wide">
        <div class="vat-feature-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="vat-feature-body">
          <h3 class="vat-feature-title">Dynamic Price Updates Across All Pages</h3>
          <p class="vat-feature-text">Prices update dynamically on product pages, collection pages, and the cart — all without a page reload. Your customers always see the correct price for their mode.</p>
        </div>
      </div>

      <!-- Feature 4 — Merchant Config -->
      <div class="vat-feature-card">
        <div class="vat-feature-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
        </div>
        <h3 class="vat-feature-title">Merchant Customization</h3>
        <p class="vat-feature-text">Set your tax rate, choose popup templates, customize colors, button text, and headings — all from the app settings panel.</p>
      </div>

      <!-- Feature 5 — Zero Code -->
      <div class="vat-feature-card">
        <div class="vat-feature-icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        </div>
        <h3 class="vat-feature-title">Zero-Code Integration</h3>
        <p class="vat-feature-text">Theme App Extension enables drag-and-drop integration. No theme code editing required — works with any Shopify 2.0 theme.</p>
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "VAT Features",
  "tag": "section",
  "class": "section",
  "presets": [
    { "name": "VAT Features" }
  ]
}
{% endschema %}
