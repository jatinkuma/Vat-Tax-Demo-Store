{%- style -%}
  /* ===== VAT SWITCHER — WHY CHOOSE US ===== */
  .vat-benefits {
    padding: 100px 0;
    background: #0C0C0C;
    position: relative;
  }
  .vat-benefits::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
  }
  .vat-benefits__header {
    text-align: center;
    margin-bottom: 56px;
  }
  .vat-benefits-container {
    background: linear-gradient(145deg, #141414, #111111);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 28px;
    padding: 64px;
    position: relative;
    overflow: hidden;
  }
  .vat-benefits-container::before {
    content: '';
    position: absolute;
    top: -80px; left: 50%; transform: translateX(-50%);
    width: 500px; height: 200px;
    background: radial-gradient(ellipse, rgba(249,115,22,0.07) 0%, transparent 70%);
    pointer-events: none;
  }
  .vat-benefits-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
    position: relative;
    z-index: 2;
  }
  .vat-benefit-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 32px 24px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 20px;
    transition: all 0.3s ease;
  }
  .vat-benefit-item:hover {
    background: rgba(249,115,22,0.04);
    border-color: rgba(249,115,22,0.15);
    transform: translateY(-4px);
  }
  .vat-benefit-icon {
    width: 56px; height: 56px;
    background: rgba(249,115,22,0.1);
    border: 1px solid rgba(249,115,22,0.2);
    border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 20px;
    color: #F97316;
    font-size: 24px;
  }
  .vat-benefit-title {
    font-size: 17px; font-weight: 700; color: #F1F5F9;
    margin: 0 0 10px; line-height: 1.3;
  }
  .vat-benefit-text {
    font-size: 14px; color: #64748B; line-height: 1.7; margin: 0;
  }
  @media screen and (max-width: 989px) {
    .vat-benefits-container { padding: 40px 32px; }
    .vat-benefits-grid { grid-template-columns: 1fr; gap: 24px; }
  }
{%- endstyle -%}

<section class="vat-benefits" aria-labelledby="vat-benefits-heading">
  <div class="page-width">
    <div class="vat-benefits__header">
      <span class="vat-section-label">Why Choose Us</span>
      <h2 class="vat-section-title" id="vat-benefits-heading">
        Why merchants love<br><span>Ests Tax/VAT Switcher</span>
      </h2>
    </div>

    <div class="vat-benefits-container">
      <div class="vat-benefits-grid">

        <div class="vat-benefit-item">
          <div class="vat-benefit-icon" aria-hidden="true">⚡</div>
          <h3 class="vat-benefit-title">Zero Code Required</h3>
          <p class="vat-benefit-text">Theme App Extension enables drag-and-drop integration. Works with any Shopify 2.0 theme without touching a single line of code.</p>
        </div>

        <div class="vat-benefit-item">
          <div class="vat-benefit-icon" aria-hidden="true">🎯</div>
          <h3 class="vat-benefit-title">B2B &amp; B2C Ready</h3>
          <p class="vat-benefit-text">Serve both business customers (excl. VAT) and individual customers (incl. VAT) from the same store — seamlessly.</p>
        </div>

        <div class="vat-benefit-item">
          <div class="vat-benefit-icon" aria-hidden="true">🎨</div>
          <h3 class="vat-benefit-title">Fully Customizable</h3>
          <p class="vat-benefit-text">Set your tax rate, choose popup templates, customize colors, button text, and headings — all from the merchant settings panel.</p>
        </div>

      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "VAT Benefits",
  "tag": "section",
  "class": "section",
  "presets": [
    { "name": "VAT Benefits" }
  ]
}
{% endschema %}
